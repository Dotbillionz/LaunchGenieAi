{
  "name": "crownops-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @crownops/backend",
    "dev:backend": "npm run dev --workspace @crownops/backend",
    "dev:frontend": "npm run dev --workspace @crownops/frontend",
    "lint": "npm run lint --workspaces --if-present"
  }
}
